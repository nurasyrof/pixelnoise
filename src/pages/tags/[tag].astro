---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const tags = [...new Set(posts.flatMap(p => p.data.tags.map(t => t.toLowerCase().replace(/\s+/g, '-'))))];
  return tags.map(tag => ({ params: { tag }, props: { tag } }));
}

const { tag } = Astro.props;
const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .filter(p => p.data.tags.some(t => t.toLowerCase().replace(/\s+/g, '-') === tag))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const tagLabel = tag.replace(/-/g, ' ');

function formatDate(date: Date) {
  return new Intl.DateTimeFormat('en-US', { month: 'long', day: 'numeric', year: 'numeric' }).format(date);
}
---
<Base title={`${tagLabel} — Pixel Noise`} description={`Articles tagged "${tagLabel}" on Pixel Noise.`}>
  <div class="page-header">
    <h1>{tagLabel}</h1>
  </div>
  <div class="container" style="padding-top: 48px; padding-bottom: 96px;">
    <div class="article-grid">
      {allPosts.map(post => (
        <div class="article-grid-item">
          <a href={`/blog/${post.slug}`} class="article-grid-card">
            {post.data.coverImage
              ? <img src={post.data.coverImage} alt={post.data.title} />
              : <div class="article-grid-card-placeholder"></div>
            }
          </a>
          <span class="article-grid-category">{post.data.category}</span>
          <a href={`/blog/${post.slug}`} class="article-grid-title">{post.data.title}</a>
        </div>
      ))}
    </div>
  </div>
</Base>
