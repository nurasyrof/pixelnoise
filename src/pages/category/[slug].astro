---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const categories = [...new Set(posts.map(p => p.data.category.toLowerCase()))];
  const navCategories = ['latest', 'trending', 'news', 'inspo'];
  const allSlugs = [...new Set([...categories, ...navCategories])];
  return allSlugs.map(slug => ({
    params: { slug },
    props: { slug },
  }));
}

const { slug } = Astro.props;
const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const filteredPosts = slug === 'latest'
  ? allPosts
  : allPosts.filter(p => p.data.category.toLowerCase() === slug);

const categoryName = slug.charAt(0).toUpperCase() + slug.slice(1);

function formatDate(date: Date) {
  return new Intl.DateTimeFormat('en-US', { month: 'long', day: 'numeric', year: 'numeric' }).format(date);
}

const navCategories = ['latest', 'trending', 'news', 'inspo'];
---
<Base title={`${categoryName} — Pixel Noise`} description={`Browse ${categoryName} articles on Pixel Noise.`}>

  <!-- Page Header -->
  <div class="page-header">
    <h1>{categoryName}</h1>
  </div>

  <div class="container">
    <!-- Filter bar -->
    <ul class="filter-bar">
      {['All', 'Latest', 'Trending', 'News', 'Inspo'].map(f => (
        <li>
          <a
            href={f === 'All' ? '/category/latest' : `/category/${f.toLowerCase()}`}
            class={slug === f.toLowerCase() || (f === 'All' && slug === 'latest') ? 'active' : ''}
          >{f}</a>
        </li>
      ))}
    </ul>

    <!-- Article Grid -->
    <div class="article-grid">
      {filteredPosts.map(post => (
        <div class="article-grid-item">
          <a href={`/blog/${post.slug}`} class="article-grid-card">
            {post.data.coverImage
              ? <img src={post.data.coverImage} alt={post.data.title} />
              : <div class="article-grid-card-placeholder"></div>
            }
          </a>
          <span class="article-grid-category">{post.data.category}</span>
          <a href={`/blog/${post.slug}`} class="article-grid-title">{post.data.title}</a>
        </div>
      ))}
    </div>

    <!-- Category Nav Row -->
    <div class="category-nav-row">
      {navCategories.map(cat => (
        <a href={`/category/${cat}`} class="category-nav-btn">
          {cat.charAt(0).toUpperCase() + cat.slice(1)}
        </a>
      ))}
    </div>
  </div>
</Base>
