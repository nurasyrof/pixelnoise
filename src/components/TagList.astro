---
interface Props {
  tags: string[];
  /**
   * When true, each tag renders as an anchor pointing to /tags/[tag].
   * When false, tags are rendered as plain non-interactive spans.
   * Defaults to true.
   */
  linked?: boolean;
}

const { tags, linked = true } = Astro.props;
---

{tags.length > 0 && (
  <ul class="tag-list" role="list">
    {tags.map((tag) =>
      linked ? (
        <li>
          <a href={`/tags/${tag}`} class="tag">
            {tag}
          </a>
        </li>
      ) : (
        <li>
          <span class="tag">{tag}</span>
        </li>
      )
    )}
  </ul>
)}
