---
import TagList from './TagList.astro';

interface Props {
  slug: string;
  title: string;
  description: string;
  pubDate: Date;
  tags: string[];
  category: string;
}

const { slug, title, description, pubDate, tags, category } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="post-card">
  <a href={`/blog/${slug}`} aria-label={`Read "${title}"`}>
    <div class="post-card__meta">
      <span class="post-card__category">{category}</span>
      <time class="post-card__date" datetime={pubDate.toISOString()}>
        {formattedDate}
      </time>
    </div>
    <h2 class="post-card__title">{title}</h2>
    <p class="post-card__description">{description}</p>
    <div class="post-card__footer">
      <TagList tags={tags} linked={false} />
      <span class="post-card__read-more" aria-hidden="true">Read &rarr;</span>
    </div>
  </a>
</article>
