---
import Base from './Base.astro';
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  coverImage?: string;
  tags: string[];
  category: string;
  readTime?: string;
  slug: string;
}

const { title, description, pubDate, coverImage, tags, category, readTime, slug } = Astro.props;

// Get prev/next posts
const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const currentIndex = allPosts.findIndex(p => p.slug === slug);
const prevPost = currentIndex < allPosts.length - 1 ? allPosts[currentIndex + 1] : null;
const nextPost = currentIndex > 0 ? allPosts[currentIndex - 1] : null;

const formattedDate = new Intl.DateTimeFormat('en-US', { month: 'long', day: 'numeric', year: 'numeric' }).format(pubDate);

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---
<Base title={title} description={description} canonicalURL={canonicalURL}>
  <!-- Post Hero -->
  <section class="post-hero">
    <div class="post-hero-inner">
      {coverImage
        ? <img class="post-hero-image" src={coverImage} alt={title} />
        : <div class="post-hero-image" style="background: var(--color-card-placeholder);"></div>
      }
      <div class="post-hero-meta">
        <span>{formattedDate}</span>
        <span class="meta-sep">·</span>
        <span>{readTime || '4 min read'}</span>
      </div>
      <h1 class="post-hero-title">{title}</h1>
    </div>
  </section>

  <!-- Tags -->
  <div class="post-tags-row">
    {tags.map(tag => (
      <a href={`/tags/${tag.toLowerCase().replace(/\s+/g, '-')}`} class="tag-lg">{tag}</a>
    ))}
  </div>

  <!-- Subtitle / Description -->
  <div style="max-width: var(--container-max); margin: 0 auto; padding: 0 var(--container-pad);">
    <p class="post-subtitle" style="padding: 0; width: 385px;">{description}</p>
  </div>

  <!-- Divider -->
  <hr class="post-divider" />

  <!-- Content -->
  <div class="post-content-wrap">
    <article class="prose">
      <slot />
    </article>
  </div>

  <!-- Prev/Next nav -->
  <nav class="post-nav" aria-label="Post navigation">
    {prevPost
      ? <a href={`/blog/${prevPost.slug}`}>← {prevPost.data.title}</a>
      : <span></span>
    }
    {nextPost
      ? <a href={`/blog/${nextPost.slug}`} style="text-align:right">{nextPost.data.title} →</a>
      : <span></span>
    }
  </nav>
</Base>
