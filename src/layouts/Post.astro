---
import Base from './Base.astro';
import TagList from '../components/TagList.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: string;
  tags: string[];
  category: string;
  rawContent?: string;
  slug: string;
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  tags,
  category,
  rawContent = '',
  slug,
} = Astro.props;

// Reading time: average 200 words per minute
const wordCount = rawContent.trim().split(/\s+/).filter(Boolean).length;
const readingTimeMinutes = Math.max(1, Math.round(wordCount / 200));
const readingTime = `${readingTimeMinutes} min read`;

const formattedPubDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const formattedUpdatedDate = updatedDate
  ? updatedDate.toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : null;

const canonicalURL = new URL(`/blog/${slug}`, Astro.site);
---

<Base
  title={title}
  description={description}
  image={heroImage}
  canonicalURL={canonicalURL}
  type="article"
>
  <article>
    <div class="container">
      <header class="post-header">
        <div class="post-header__meta">
          <span class="post-header__category">{category}</span>
          <span aria-hidden="true" style="color: var(--color-border);">·</span>
          <time
            class="post-header__date"
            datetime={pubDate.toISOString()}
            title={formattedPubDate}
          >
            {formattedPubDate}
          </time>
          <span aria-hidden="true" style="color: var(--color-border);">·</span>
          <span class="post-header__reading-time">{readingTime}</span>
        </div>

        <h1 class="post-header__title">{title}</h1>
        <p class="post-header__description">{description}</p>

        {tags.length > 0 && (
          <div class="post-header__tags">
            <TagList tags={tags} linked={true} />
          </div>
        )}

        {formattedUpdatedDate && (
          <p style="margin-top: var(--space-4); font-size: var(--text-sm); color: var(--color-muted);">
            Last updated: <time datetime={updatedDate?.toISOString()}>{formattedUpdatedDate}</time>
          </p>
        )}
      </header>

      {heroImage && (
        <img
          src={heroImage}
          alt=""
          role="presentation"
          style="width: 100%; border-radius: var(--radius-lg); margin-bottom: var(--space-10); aspect-ratio: 16/9; object-fit: cover;"
        />
      )}

      <div class="prose">
        <slot />
      </div>

      <footer class="post-footer">
        <a href="/blog" class="post-footer__back">
          &larr; All posts
        </a>
      </footer>
    </div>
  </article>
</Base>
